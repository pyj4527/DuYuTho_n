{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "vapid:generate": "bun scripts/generate-vapid-env.ts",
    "env:local-production": "bun scripts/generate-vapid-env.ts --write",
    "typecheck": "bunx --bun tsc -p tsconfig.backend.json --noEmit",
    "validate": "bun run db:validate && bun run typecheck",
    "build": "bun run validate",
    "db:generate": "bunx --bun prisma generate",
    "db:validate": "bunx --bun prisma validate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:studio": "bunx --bun prisma studio",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@clerk/backend": "^3.4.13",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.28",
    "openai": "^6.38.0",
    "pg": "^8.21.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  }
}
