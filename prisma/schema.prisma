generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id                     String   @id @default(uuid())
  name                   String
  memberCount            Int      @default(2)
  timezone               String   @default("Asia/Seoul")
  defaultStorageLocation String   @default("냉장")

  profile          UserProfile?
  settings         HouseholdSettings?
  inventoryItems   InventoryItem[]
  selection        InventorySelection?
  lensAnalyses     LensAnalysis[]
  recipes          Recipe[]
  recipeSaves      RecipeSave[]
  consumptionLogs  RecipeConsumptionLog[]
  pushSubscriptions PushSubscription[]
  prototypeImports PrototypeImport[]
  idempotencyKeys  IdempotencyRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id          String @id @default(uuid())
  householdId String @unique
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  nickname  String
  email     String?
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HouseholdSettings {
  id          String @id @default(uuid())
  householdId String @unique
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  excludedIngredients         String[] @default([])
  dislikedFoods              String[] @default([])
  allergies                  String[] @default([])
  preferredCookTimeMinutes   Int?
  mildFlavorPreferred        Boolean?

  expiryReminderEnabled        Boolean @default(true)
  expiryReminderDaysBefore     Int[]   @default([2, 0])
  expiryReminderTime           String  @default("09:00")
  recipeConsumeReminderEnabled Boolean @default(true)
  reviewPendingReminderEnabled Boolean @default(true)
  quietHoursStart              String?
  quietHoursEnd                String?

  theme                  String?
  onboardingCompleted    Boolean?
  onboardingCompletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  name           String
  quantityLabel  String
  quantityAmount Float?
  quantityUnit   String?
  location       String
  expiresAt      String

  status   String @default("active")
  source   String @default("manual")
  category String?
  memo     String?

  sourceAnalysisId String?
  clientRequestId  String?

  discardedAt DateTime?
  consumedAt  DateTime?
  deletedAt   DateTime?
  version     Int       @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([householdId, status])
  @@index([householdId, expiresAt])
  @@index([householdId, createdAt])
  @@index([householdId, name])
}

model InventorySelection {
  id          String @id @default(uuid())
  householdId String @unique
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  selectedIngredientIds String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LensAnalysis {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  status       String
  source       String
  rawText      String?
  imageMime    String?
  imageSize    Int?
  result       Json?
  problem      Json?
  providerName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([householdId, status])
  @@index([createdAt])
}

model Recipe {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  name          String
  ingredients   Json
  saved         Boolean @default(false)
  time          String
  timeMinutes   Int?
  description   String?
  imageUrl      String?
  servings      Int?
  difficulty    String?
  tags          String[] @default([])
  dietaryFlags  String[] @default([])
  steps         Json?
  nutrition     Json?
  source        String @default("migration")
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([householdId, name])
  @@index([householdId, deletedAt])
}

model RecipeSave {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  recipeId String
  saved    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([householdId, recipeId])
  @@index([householdId])
}

model RecipeConsumptionLog {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  recipeId              String
  recipeName            String
  consumedAt            DateTime
  selectedIngredientIds String[] @default([])
  updatedItemIds        String[] @default([])
  removedItemIds        String[] @default([])

  createdAt DateTime @default(now())

  @@index([householdId])
  @@index([householdId, consumedAt])
}

model PushSubscription {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  endpoint       String
  expirationTime BigInt?
  p256dh         String
  auth           String
  userAgent      String?
  timezone       String
  deviceLabel    String?
  active         Boolean @default(true)
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([householdId, endpoint])
  @@index([householdId])
  @@index([householdId, active])
}

model PrototypeImport {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  source            String
  clientGeneratedAt DateTime
  strategy          String
  importedItems     Int
  importedRecipes   Int
  importedSelections Int
  idMap             Json
  skipped           Json

  createdAt DateTime @default(now())

  @@index([householdId])
  @@index([createdAt])
}

model IdempotencyRecord {
  id          String @id @default(uuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  endpoint     String
  key          String
  requestHash  String
  responseBody Json
  status       Int
  expiresAt    DateTime

  createdAt DateTime @default(now())

  @@unique([householdId, endpoint, key])
  @@index([expiresAt])
}
