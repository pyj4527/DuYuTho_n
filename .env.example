# Local production defaults for localhost smoke testing.
# Real production: use real HTTPS origins and keep anonymous household fallback disabled.
PORT=3000
NODE_ENV=production
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:4173,http://localhost:5173,http://127.0.0.1:4173,http://127.0.0.1:5173"
# Frontend build output served at /. Relative paths resolve from the backend working directory.
FRONTEND_DIST_DIR="../frontend/dist"
DEFAULT_HOUSEHOLD_ID="hh_default"
DEFAULT_USER_ID="user_default"
# `bun run env:local-production` writes this as true only to ignored local .env.
ALLOW_ANONYMOUS_HOUSEHOLD="false"
RATE_LIMIT_LENS_IMAGE_PER_HOUR=30
RATE_LIMIT_LENS_TEXT_PER_HOUR=120
RATE_LIMIT_RECIPE_IMPORT_PER_HOUR=20
RATE_LIMIT_PUSH_TEST_PER_HOUR=10
RATE_LIMIT_PROTOTYPE_IMPORT_PER_DAY=20

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fridge_waste?schema=public"

S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="uploads"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-5.4-mini"
OPENAI_TEXT_MODEL="gpt-5.4-mini"
LENS_IMAGE_ALLOW_MOCK_FALLBACK="false"
LENS_TEXT_ALLOW_RULE_FALLBACK="false"
RECIPE_AUTO_CRAWL_ENABLED="true"
RECIPE_AUTO_CRAWL_TARGET_COUNT=6
RECIPE_AI_RERANK_ENABLED="true"
RECIPE_AI_RERANK_MAX_CANDIDATES=20
RECIPE_CRAWL_ALLOWED_HOSTS="10000recipe.com,www.10000recipe.com"
RECIPE_CRAWL_URLS=""
RECIPE_CRAWL_TIMEOUT_MS=8000
RECIPE_CRAWL_MAX_BYTES=2000000
# Frontend counterpart: VITE_CLERK_PUBLISHABLE_KEY in ../frontend. Leave both empty for the anonymous-household prototype flow.
CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Optional networkless verification public key from Clerk. Leave empty to use CLERK_SECRET_KEY/JWKS verification.
CLERK_JWT_KEY=""
# Comma-separated frontend origins allowed in Clerk session token azp checks.
CLERK_AUTHORIZED_PARTIES="http://localhost:3000,http://localhost:4173,http://localhost:5173,http://127.0.0.1:4173,http://127.0.0.1:5173"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Replace with a real mailto: or https: contact before actual push delivery.
VAPID_SUBJECT="mailto:local-production@example.invalid"
